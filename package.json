{
  "name": "la-esquina-kiosco",
  "version": "0.1.0",
  "packageManager": "pnpm@10.28.2",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "deploy": "pnpm run build && firebase deploy",
    "build:mobile": "cross-env IS_MOBILE_BUILD=true next build && npx cap sync",
    "open:android": "npx cap open android",
    "electron:dev": "concurrently -k \"cross-env BROWSER=none pnpm run dev\" \"wait-on tcp:3000 && electron .\"",
    "electron:build": "cross-env NEXT_PUBLIC_IS_ELECTRON=true next build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "com.almacenmgd.desktop",
    "productName": "Almacen MGD",
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "electron/**/*",
      "package.json"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Almacen MGD",
      "runAfterFinish": true
    },
    "win": {
      "target": "nsis"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ivanlamo01",
        "repo": "Lo-de-Marta"
      }
    ]
  },
  "dependencies": {
    "@afipsdk/afip.js": "^1.2.2",
    "@capacitor-community/sqlite": "^8.0.0",
    "@capacitor-firebase/authentication": "^8.1.0",
    "@capacitor/android": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@genkit-ai/firebase": "^1.25.0",
    "@genkit-ai/googleai": "^1.25.0",
    "better-sqlite3": "^12.6.2",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "driver.js": "^1.4.0",
    "electron-serve": "^3.0.0",
    "electron-store": "^6.0.1",
    "electron-updater": "^6.7.3",
    "firebase": "^12.3.0",
    "firebase-admin": "^13.5.0",
    "firebase-frameworks": "^0.11.8",
    "genkit": "^1.25.0",
    "next": "16.0.8",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-icons": "^5.5.0",
    "react-qr-code": "^2.0.18",
    "react-to-print": "^3.2.0",
    "recharts": "^3.2.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-icons": "^2.2.7",
    "@types/uuid": "^10.0.0",
    "baseline-browser-mapping": "^2.10.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "electron-reload": "^2.0.0-alpha.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "firebase-tools": "^14.27.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.3"
  },
  "optionalDependencies": {
    "@next/swc-win32-x64-msvc": "^16.0.8"
  }
}
